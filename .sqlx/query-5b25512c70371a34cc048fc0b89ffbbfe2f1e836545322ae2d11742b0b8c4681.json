  "query": "\n            INSERT INTO sar_narratives (id, sar_id, version, narrative_text, author_id, created_at)\n            VALUES (\n                $1, $2,\n                COALESCE((SELECT MAX(version) FROM sar_narratives WHERE sar_id = $2), 0) + 1,\n                $3, $4, NOW()\n            )\n            RETURNING *\n            ",
