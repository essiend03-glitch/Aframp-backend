{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, peer_id, agent_id, endpoint,\n                   tier AS \"tier: PeerTier\",\n                   reputation, last_seen_at, created_at\n            FROM swarm_peers\n            WHERE tier != 'revoked'\n              AND ($1::peer_tier IS NULL OR tier = $1)\n            ORDER BY reputation DESC, last_seen_at DESC\n            LIMIT $2 OFFSET $3\n            ",
