  "query": "SELECT f.* FROM pentest_findings f\n               JOIN pentest_engagements e ON f.engagement_id = e.id\n               WHERE e.id = $1 AND f.severity IN ('critical', 'high')\n               AND f.status NOT IN ('verified_closed')\n               AND f.disputed = false",
