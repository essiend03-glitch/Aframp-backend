{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT p.id, p.name, p.description, p.category, p.created_at, p.updated_at\n            FROM admin_permissions p\n            JOIN admin_role_permissions rp ON p.id = rp.permission_id\n            WHERE rp.role = $1\n            ORDER BY p.category, p.name\n            ",
