  "query": "\n        SELECT ak.id, ak.consumer_id, c.consumer_type\n        FROM api_keys ak\n        JOIN consumers c ON c.id = ak.consumer_id\n        WHERE ak.id = $1 AND ak.consumer_id = $2 AND ak.is_active = TRUE\n        ",
