  "query": "\n            SELECT id, service_id, certificate_pem, private_key_ref,\n                   serial_number, issued_at, expires_at, revoked\n            FROM service_certificates\n            WHERE NOT revoked AND expires_at < $1\n            ORDER BY expires_at\n            ",
